# =============================================================
# Minecraft Mod ディレクトリ用 .gitignore
# バイナリファイルはGitで追跡しない（mods_list.json でリスト管理する）
# =============================================================

# --- バイナリ mod ファイル ---
*.jar
*.zip
*.7z
*.ysm

# --- OS 生成ファイル ---
.DS_Store
Thumbs.db
desktop.ini

# --- Python スクリプト用 ---
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/

shader-test/

# =============================================================
# 以下のファイルは Git で追跡する（明示的に許可）
# =============================================================

# mod のリスト情報（バイナリのリストをJSONで管理）
!mods_list.json

# スクリプト類
!scripts/

# 設定ファイル類
!*.json
!*.toml
!*.cfg
!*.conf
!*.properties
!*.txt
!*.md
